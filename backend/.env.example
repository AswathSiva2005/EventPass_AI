NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eventpass_ai?retryWrites=true&w=majority
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-32-character-random-secret
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_EXPIRES_IN=30d
JWT_ACTION_SECRET=replace-with-a-third-32-character-random-secret
JWT_ACTION_EXPIRES_IN=10m
JWT_ISSUER=eventpass-ai
JWT_AUDIENCE=eventpass-ai-clients
OTP_PEPPER=replace-with-an-independent-32-character-random-secret
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
PASSWORD_BCRYPT_ROUNDS=12
QR_SIGNING_SECRET=replace-with-an-independent-32-character-random-secret
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
MAX_UPLOAD_SIZE_MB=5
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=EventPass AI <no-reply@example.com>
