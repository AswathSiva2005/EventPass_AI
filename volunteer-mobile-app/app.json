{
  "expo": {
    "name": "EventPass Volunteer",
    "slug": "eventpass-volunteer-mobile",
    "scheme": "eventpassvolunteer",
    "version": "1.0.0",
    "orientation": "default",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sharing"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b1220"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
